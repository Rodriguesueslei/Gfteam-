rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.lower() == "rodrigues.ueslei@gmail.com" || 
        request.auth.token.email.lower() == "ueslei.rodrigues@gmail.com" ||
        request.auth.uid == "MtaH6LrL5vbL8Dp7pZxPeQrEJyP2"
      );
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // The core of multi-tenancy: get the tenantId from the user profile document
    function userTenantId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId;
    }

    function isTenantAdmin() {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'tenant_admin']
      );
    }

    function isTenantStaff() {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'tenant_admin', 'receptionist', 'professor']
      );
    }

    function belongsToUserTenant(data) {
      return isSuperAdmin() || (isAuthenticated() && data.tenantId == userTenantId());
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ===============================================================
    // Rules
    // ===============================================================

    match /tenants/{tenantId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || tenantId == userTenantId());
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow list: if isAuthenticated() && (
        isSuperAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && isTenantStaff())
      );
      allow get: if isAuthenticated() && (
        isSuperAdmin() ||
        request.auth.uid == userId || 
        request.auth.token.email.lower() == userId.lower() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && isTenantStaff() && belongsToUserTenant(existing()))
      );
      allow create: if isAuthenticated() && (
        isSuperAdmin() ||
        (request.auth.uid == userId) ||
        (request.auth.token.email.lower() == userId.lower())
      );
      allow update: if isSuperAdmin() || (
        isAuthenticated() && request.auth.uid == userId && 
        (!('tenantId' in incoming()) || incoming().tenantId == existing().tenantId) &&
        (!('role' in incoming()) || incoming().role == existing().role)
      ) || (
        isTenantAdmin() && belongsToUserTenant(existing()) &&
        (!('tenantId' in incoming()) || incoming().tenantId == existing().tenantId)
      );
      allow delete: if isSuperAdmin();
    }

    // Catch-all for most tenant collections
    match /{collectionName}/{docId} {
      allow read: if isSuperAdmin() || (
        isAuthenticated() && (
          // Staff can read all tenant documents
          (isTenantStaff() && belongsToUserTenant(existing())) ||
          
          // Users can read public stuff like classes/plans
          (collectionName in ['classes', 'plans', 'instructors', 'products', 'belts', 'settings'] && belongsToUserTenant(existing()))
        )
      );

      allow create: if isSuperAdmin() || (
        isAuthenticated() && isTenantStaff() && 
        incoming().tenantId == userTenantId()
      );

      allow update, delete: if isSuperAdmin() || (
        isAuthenticated() && isTenantAdmin() && 
        belongsToUserTenant(existing()) &&
        (!('tenantId' in incoming()) || incoming().tenantId == existing().tenantId)
      );
    }

    // Specific overrides or subcollections
    match /classes/{classId}/checkIns/{checkInId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToUserTenant(get(/databases/$(database)/documents/classes/$(classId)).data));
      allow create: if isAuthenticated() && belongsToUserTenant(get(/databases/$(database)/documents/classes/$(classId)).data);
    }

    match /licenses/{licenseId} {
      // Allow public read for tenant lookup by slug, but only if they are authenticated or it is a single doc read
      allow read: if true; 
      allow write: if isSuperAdmin();
    }
  }
}
