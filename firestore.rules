rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "rodrigues.ueslei@gmail.com" || 
              request.auth.uid == "MtaH6LrL5vbL8Dp7pZxPeQrEJyP2");
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // The core of multi-tenancy: get the tenantId from the user profile document
    function userTenantId() {
      return getUserData().tenantId;
    }

    function isTenantAdmin() {
      return isAuthenticated() && (isSuperAdmin() || getUserData().role == 'admin');
    }

    function isTenantStaff() {
      return isAuthenticated() && (isTenantAdmin() || getUserData().role in ['receptionist', 'professor']);
    }

    function belongsToUserTenant(data) {
      return isSuperAdmin() || (isAuthenticated() && data.tenantId == userTenantId());
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation patterns
    function isValidStudent(data) {
      return data.name is string && data.name.size() > 0 && 
             data.email is string && 
             data.tenantId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /tenants/{tenantId} {
      allow read: if isAuthenticated() && (tenantId == userTenantId() || isSuperAdmin());
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || (belongsToUserTenant(existing()) && isTenantStaff()) || isSuperAdmin());
      allow create: if isAuthenticated() && (
        (request.auth.uid == userId && incoming().role == 'user' && (incoming().tenantId == 'default_gym' || incoming().tenantId == null)) ||
        isSuperAdmin()
      );
      allow update: if isSuperAdmin() || (
        isAuthenticated() && request.auth.uid == userId && 
        (!('tenantId' in incoming()) || incoming().tenantId == existing().tenantId) &&
        (!('role' in incoming()) || incoming().role == existing().role)
      ) || (
        isTenantAdmin() && belongsToUserTenant(existing()) &&
        (!('tenantId' in incoming()) || incoming().tenantId == existing().tenantId)
      );
    }

    // Catch-all for most tenant collections
    match /{collectionName}/{docId} {
      allow read: if isSuperAdmin() || (
        isAuthenticated() && (
          // If it is a list query, the client must filter by tenantId (which is checked by belongsToUserTenant)
          (belongsToUserTenant(existing()) && (isTenantStaff() || collectionName in ['classes', 'plans', 'instructors', 'products'])) ||
          
          // Students reading their own data check (would require a join in rules, usually avoided for efficiency)
          // For now, let's keep it simple: Staff can read all tenant data, users can read "public" tenant data like classes.
          (collectionName in ['classes', 'plans', 'instructors', 'products'] && belongsToUserTenant(existing()))
        )
      );

      allow create: if isSuperAdmin() || (
        isAuthenticated() && isTenantStaff() && 
        incoming().tenantId == userTenantId()
      );

      allow update, delete: if isSuperAdmin() || (
        isAuthenticated() && isTenantAdmin() && 
        belongsToUserTenant(existing()) &&
        (!('tenantId' in incoming()) || incoming().tenantId == existing().tenantId)
      );
    }

    // Specific overrides or subcollections
    match /classes/{classId}/checkIns/{checkInId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToUserTenant(get(/databases/$(database)/documents/classes/$(classId)).data));
      allow create: if isAuthenticated() && belongsToUserTenant(get(/databases/$(database)/documents/classes/$(classId)).data);
    }

    match /licenses/{licenseId} {
      allow read, write: if isSuperAdmin();
    }
  }
}
